---
import CourseCard from '../components/CourseCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCourses } from '../lib/courses';
import { profile } from '../lib/i18n';

const courses = await getCourses();
---

<BaseLayout
	locale="en"
	title="Ray"
	description="I am a PhD student in Economics at Renmin University of China, interested in labor economics, development economics, and the Chinese labor market."
	currentSection="home"
	alternatePath="/zh/"
>
	<section class="hero container">
		<div class="hero-main">
			<p class="eyebrow">Economics · Research & Teaching</p>
			<h1>Labor, development, and the Chinese labor market.</h1>
			<p class="hero-copy">{profile.research.en}</p>
			<div class="button-row">
				<a class="button" href="/teaching/">Teaching</a>
				<a class="button secondary" href="/about/">About Ray</a>
			</div>
		</div>
		<aside class="hero-aside" aria-label="Academic affiliation">
			<p class="role">{profile.role.en}</p>
			<p class="affiliation">{profile.affiliation.en}</p>
		</aside>
	</section>

	<section class="section">
		<div class="section-grid container">
			<p class="section-label">Profile</p>
			<div class="prose">
				<h2>Economics with a focus on labor and development.</h2>
				<p>I am a PhD student in Economics at Renmin University of China.</p>
				<p>My research interests are in labor economics and development economics, with a focus on the Chinese labor market.</p>
				<a class="text-link" href="/about/">Read the profile<span aria-hidden="true"> ↗</span></a>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section-grid container">
			<p class="section-label">Teaching</p>
			<div>
				<h2 class="section-heading">Current course</h2>
				<div class="course-grid">
					{courses.map((course, index) => <CourseCard course={course} locale="en" index={index} />)}
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
