---
import type { CollectionEntry } from 'astro:content';
import ResourceList from '../../../components/ResourceList.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { courseSlug, getCourses } from '../../../lib/courses';

export async function getStaticPaths() {
	const courses = await getCourses();
	return courses.map((course) => ({
		params: { course: courseSlug(course.id) },
		props: { course },
	}));
}

interface Props {
	course: CollectionEntry<'courses'>;
}

const { course } = Astro.props;
const slug = courseSlug(course.id);
---

<BaseLayout
	locale="zh"
	title={course.data.title.zh}
	description={course.data.description.zh}
	currentSection="teaching"
	alternatePath={`/teaching/${slug}/`}
>
	<header class="page-header container">
		<p class="eyebrow">教学</p>
		<h1>{course.data.title.zh}</h1>
		<p class="page-intro">{course.data.description.zh}</p>
	</header>

	<section class="section">
		<div class="section-grid container">
			<p class="section-label">课程资料</p>
			<ResourceList course={course} locale="zh" />
		</div>
	</section>
</BaseLayout>
