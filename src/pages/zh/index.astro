---
import CourseCard from '../../components/CourseCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCourses } from '../../lib/courses';
import { profile } from '../../lib/i18n';

const courses = await getCourses();
---

<BaseLayout
	locale="zh"
	title="Ray"
	description="我是中国人民大学经济学博士生，研究兴趣为劳动经济学与发展经济学，重点关注中国劳动力市场。"
	currentSection="home"
	alternatePath="/"
>
	<section class="hero container">
		<div class="hero-main">
			<p class="eyebrow">经济学 · 研究与教学</p>
			<h1>劳动与发展。</h1>
			<p class="hero-copy">{profile.research.zh}</p>
			<div class="button-row">
				<a class="button" href="/zh/teaching/">教学</a>
				<a class="button secondary" href="/zh/about/">关于 Ray</a>
			</div>
		</div>
		<aside class="hero-aside" aria-label="学术身份">
			<p class="role">{profile.role.zh}</p>
			<p class="affiliation">{profile.affiliation.zh}</p>
		</aside>
	</section>

	<section class="section">
		<div class="section-grid container">
			<p class="section-label">教学</p>
			<div>
				<h2 class="section-heading">当前课程</h2>
				<div class="course-grid">
					{courses.map((course, index) => <CourseCard course={course} locale="zh" index={index} />)}
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
