---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../lib/i18n';
---

<BaseLayout
	locale="en"
	title="About"
	description="I am a PhD student in Economics at Renmin University of China, interested in labor economics and development economics."
	currentSection="about"
	alternatePath="/zh/about/"
>
	<header class="page-header container">
		<p class="eyebrow">About</p>
		<h1>Economics, labor, and development.</h1>
		<p class="page-intro">{profile.research.en}</p>
	</header>

	<section class="section">
		<div class="section-grid container">
			<p class="section-label">Profile</p>
			<div class="prose">
				<h2>Ray</h2>
				<p>I am a PhD student in Economics at {profile.affiliation.en}.</p>
				<p>My research interests are in labor economics and development economics, with a focus on the Chinese labor market.</p>
			</div>
		</div>
	</section>
</BaseLayout>
