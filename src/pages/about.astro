---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../lib/i18n';
---

<BaseLayout
	locale="en"
	title="About"
	description="I am a PhD student in Economics at Renmin University of China, interested in labor economics and development economics."
	currentSection="about"
	alternatePath="/zh/about/"
>
	<header class="page-header container">
		<p class="eyebrow">About</p>
		<h1>Ray</h1>
		<p class="page-intro">I am a PhD student in Economics at {profile.affiliation.en}. My research interests are in labor economics and development economics, with a focus on the Chinese labor market.</p>
	</header>
</BaseLayout>
